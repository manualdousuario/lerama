{
    "name": "lerama/feed-aggregator",
    "description": "A feed aggregator application supporting multiple feed formats",
    "type": "project",
    "require": {
        "php": "^8.4",
        "vlucas/phpdotenv": "^5.6",
        "league/climate": "^3.10",
        "league/route": "^5.1",
        "simplepie/simplepie": "1.9.0",
        "sergeytsalkov/meekrodb": "^2.5",
        "laminas/laminas-diactoros": "^3.8",
        "laminas/laminas-httphandlerrunner": "^2.13",
        "league/plates": "^3.6",
        "guzzlehttp/guzzle": "^7.10",
        "phpmailer/phpmailer": "^6.12",
        "gregwar/captcha": "1.3",
        "predis/predis": "^3.3"
    },
    "autoload": {
        "psr-4": {
            "Lerama\\": "src/"
        }
    },
    "scripts": {
        "post-create-project-cmd": [
            "php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    }
}
